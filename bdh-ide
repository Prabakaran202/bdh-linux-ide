#!/bin/bash

SESSION="archide"
CONFIG_DIR="/etc/bdh-ide"

# =========================================================
# ⚙️ CUSTOM WINDOW SIZES (அளவுகளை இங்கு மாற்றிக்கொள்ளலாம்)
# அளவுகளை சதவீதத்தில் (Percentage 1-100) கொடுக்கவும்
# =========================================================

TERMINAL_HEIGHT=40   # கீழே உள்ள Terminal-இன் உயரம் (உதாரணம்: 40%)
NANO_WIDTH=50        # வலதுபுறம் உள்ள Nano-வின் அகலம் (உதாரணம்: 50%)

# குறிப்பு: Nano அகலத்தைக் குறைத்தால், இடதுபுறமுள்ள Ranger-ன் அகலம் தானாக அதிகரிக்கும்.
# =========================================================

tmux has-session -t $SESSION 2>/dev/null

if [ $? != 0 ]; then
    tmux -f "$CONFIG_DIR/tmux.conf" new-session -d -s $SESSION

    # 1. திரையை மேலேயும் கீழேயுமாகப் பிரிக்கிறோம் (Terminal Height)
    tmux split-window -v -p $TERMINAL_HEIGHT
    tmux select-pane -t 0

    # 2. மேலேயுள்ள பகுதியை இடது (Ranger), வலது (Nano) எனப் பிரிக்கிறோம் (Nano Width)
    tmux split-window -h -p $NANO_WIDTH

    # Ranger (Top-Left)
    tmux select-pane -t 0
    tmux send-keys "ranger" C-m

    # Nano (Top-Right)
    tmux select-pane -t 1
    tmux send-keys "nano -f $CONFIG_DIR/nanorc" C-m

    # Main Terminal (Bottom)
    tmux select-pane -t 2
fi

tmux attach -t $SESSION
