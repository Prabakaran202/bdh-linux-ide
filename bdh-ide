#!/bin/bash

# =========================================================
# Safety Lock: ஏற்கனவே Tmux-ல் இருந்தால் தடுத்துவிடுவது
# =========================================================
if [ -n "$TMUX" ]; then
    echo -e "\e[1;31m❌ பிழை: நீங்கள் ஏற்கனவே ஒரு Tmux செஷனுக்குள் உள்ளீர்கள்!\e[0m"
    echo -e "\e[1;33m💡 'exit' என்று டைப் செய்து வெளியேறிய பின் மீண்டும் 'bdh-ide' என ரன் செய்யவும்.\e[0m"
    exit 1
fi
# =========================================================

SESSION="archide"
CONFIG_DIR="/etc/bdh-ide"

# Tmux செஷன் இருக்கிறதா என செக் செய்கிறோம்
tmux has-session -t $SESSION 2>/dev/null

# செஷன் இல்லை என்றால் (Python-ன் if os.system(...) != 0 லாஜிக்)
if [ $? != 0 ]; then
    echo -e "\e[1;32m🚀 [BDH IDE] Launching Workspace with Tamizhi...\e[0m"

    # 1. Wrapper Script உருவாக்கம் (Ranger -> Nano வசதிக்காக)
    WRAPPER="/tmp/bdh-nano-wrapper.sh"
    cat <<EOF > $WRAPPER
#!/bin/bash
[ "\$1" == "--" ] && shift
FILE_PATH="\$1"
DIR_PATH=\$(dirname "\$FILE_PATH")
tmux send-keys -t 1 C-c
sleep 0.1
tmux send-keys -t 1 "nano -f $CONFIG_DIR/nanorc \"\$FILE_PATH\"" C-m
tmux send-keys -t 2 C-c
sleep 0.1
tmux send-keys -t 2 "cd \"\$DIR_PATH\" && clear && ls" C-m
tmux select-pane -t 1
EOF
    chmod +x $WRAPPER

    # 2. உங்களின் தமிழி ஸ்கிரிப்ட்டைக் கால் செய்கிறோம்!
    TMUX=''tamizhi run "$CONFIG_DIR/ide_layout.tz"
fi

# இறுதியாக செஷனை ஓபன் செய்கிறோம்
tmux attach -t $SESSION
