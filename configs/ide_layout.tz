main {
    call tmux -f /etc/bdh-ide/tmux.conf new-session -d -s archide ;
    
    // விண்டோக்களைப் பிரித்தல்
    call tmux split-window -v -p 30 ;
    call tmux select-pane -t 0 ;
    call tmux split-window -h -p 50 ;
    
    // Ranger ஓபன் செய்தல்
    call tmux select-pane -t 0;
    call tmux send-keys \export EDITOR=/tmp/bdh-nano-wrapper.sh; clear; ranger\ C-m ;
    
    // Terminal ரெடி செய்தல்
    call tmux select-pane -t 2 ;
}
