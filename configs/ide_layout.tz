main {
    // Session setup
    call tmux new-session -d -s archide ;

    // Window Layout
    call tmux split-window -v -p 30 ;
    call tmux split-window -h -p 50 ;

    // pane 0 - Ranger
    call tmux send-keys -t 0 ranger C-m ;

    // pane 1 - Nano (Wrapper மூலமாக)
    call tmux send-keys -t 1 nano C-m ;

    // pane 2 - Terminal
    call tmux select-pane -t 2 ;
}
