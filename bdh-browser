#!/bin/bash

URL="${1:-}"

echo "Starting minimal GUI browser session..."
echo "Detecting HDMI and configuring display via wlr-randr..."

# Cage-க்குள் ரன் ஆவதற்காக sh -c பயன்படுத்துகிறோம்.
# 1. wlr-randr மூலம் HDMI-A-1 ஆக்டிவேட் செய்யப்படும்.
# 2. அதன் பிறகு Firefox திறக்கப்படும்.
if [ -z "$URL" ]; then
    cage -- sh -c "wlr-randr --output HDMI-A-1 --on 2>/dev/null; exec firefox"
else
    cage -- sh -c "wlr-randr --output HDMI-A-1 --on 2>/dev/null; exec firefox \"$URL\""
fi

echo "Browser session closed. Back to BDH IDE."
